# Wovi Reserve — all optional. The app runs fully with NONE of these set; each
# one lights up a production integration. Copy to .env.local to use locally.

# --- Auth (#1) — sign-in is OFF by default; turn it on for multi-user/prod ---
# WOVI_AUTH=on             # require login + roles + segregation of duties

# --- Database & hosting (#4) ---
# WOVI_DB_PATH=/data/wovi.db          # persistent volume path in production
# WOVI_UPLOAD_DIR=/data/uploads       # attachment storage dir (#9)
# WOVI_BACKUP_DIR=/data/backups       # where `npm run backup` writes
# WOVI_BACKUP_KEEP=14

# --- Base URL for links in emails/notifications (#10) ---
# WOVI_BASE_URL=https://reserve.yourco.com

# --- Signing secret for approval magic-links & sessions (#5/#10) ---
# WOVI_SECRET=change-me-to-a-long-random-string

# --- Email delivery (#2) — also run: npm install nodemailer ---
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Reserve <reserve@yourco.com>

# --- AI quote parsing (#3) — falls back to the heuristic parser if unset ---
# WOVI_AI_KEY=
# WOVI_AI_MODEL=claude-sonnet-5
# WOVI_AI_BASE_URL=https://api.anthropic.com

# --- Scheduler SLA windows (#6) ---
# WOVI_FOLLOWUP_HOURS=4
# WOVI_ESCALATION_HOURS=6
# CRON_SECRET=change-me            # protects POST /api/cron

# --- Analytics baseline (#8) ---
# WOVI_BASELINE_DELAY_HOURS=72
